---
import "@/styles/global.css";
import "@fontsource-variable/geist";
import "@fontsource-variable/geist-mono";

interface Props {
  title?: string;
  description?: string;
}

const {
  title,
  description = "Personal site of Anurag Banerjee — posts, weeknotes, and zettles.",
} = Astro.props;

const pageTitle = title ? `${title} · Anurag Banerjee` : "Anurag Banerjee";
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Anurag Banerjee"
      href={new URL("rss.xml", Astro.site)}
    />
    <title>{pageTitle}</title>
  </head>
  <body
    class="bg-white font-sans text-zinc-900 antialiased dark:bg-zinc-950 dark:text-zinc-100"
  >
    <div class="mx-auto flex min-h-screen max-w-2xl flex-col px-6 py-10">
      <header class="mb-12 flex flex-wrap items-baseline justify-between gap-4">
        <a href="/" class="font-semibold tracking-tight">Anurag Banerjee</a>
        <nav
          class="flex gap-5 text-sm text-zinc-500 *:transition-colors *:hover:text-zinc-900 dark:text-zinc-400 dark:*:hover:text-zinc-100"
        >
          <a href="/posts">Posts</a>
          <a href="/weeknotes">Weeknotes</a>
          <a href="/zettles">Zettles</a>
        </nav>
      </header>

      <main class="flex-1">
        <slot />
      </main>

      <footer
        class="mt-16 flex flex-wrap items-baseline justify-between gap-4 border-t border-zinc-200 pt-6 text-sm text-zinc-500 dark:border-zinc-800 dark:text-zinc-400"
      >
        <p>© {year} Anurag Banerjee</p>
        <nav
          class="flex gap-4 *:transition-colors *:hover:text-zinc-900 dark:*:hover:text-zinc-100"
        >
          <a href="https://x.com/ianuragbanerjee" target="_blank" rel="me">X</a>
          <a href="https://github.com/banuragaxioned" target="_blank" rel="me"
            >GitHub</a
          >
          <a
            href="https://linkedin.com/in/imanuragbanerjee"
            target="_blank"
            rel="me">LinkedIn</a
          >
          <a href="/rss.xml">RSS</a>
        </nav>
      </footer>
    </div>
  </body>
</html>
