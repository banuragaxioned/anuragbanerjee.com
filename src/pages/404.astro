---
import Layout from "@/layouts/layout.astro";
import { buttonVariants } from "@/components/ui/button";
---

<Layout title="Page not found" description="This page doesn't exist.">
  <section class="flex flex-col items-start justify-center py-16">
    <p
      class="text-muted-foreground text-sm font-medium tracking-wide uppercase"
    >
      404
    </p>
    <h1 class="mt-3 text-4xl font-semibold tracking-tight text-balance">
      This page doesn't exist.
    </h1>
    <p class="text-muted-foreground mt-4">
      Maybe it moved during the migration from Medium, or maybe it never
      existed. Either way, there's nothing here.
    </p>
    <div class="mt-8 flex flex-wrap gap-3">
      <a href="/" class={buttonVariants({ variant: "default" })}>Go home</a>
      <a href="/posts" class={buttonVariants({ variant: "outline" })}
        >Browse posts</a
      >
    </div>
  </section>
</Layout>
