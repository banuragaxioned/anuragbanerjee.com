---
import { getCollection } from "astro:content";
import Layout from "@/layouts/layout.astro";
import EntryList from "@/components/entry-list.astro";

const zettles = await getCollection("zettles");
---

<Layout title="Zettles" description="Short notes by Anurag Banerjee.">
  <h1 class="mb-8 text-3xl font-semibold tracking-tight">Zettles</h1>
  <EntryList
    entries={zettles.map((zettle) => ({
      href: `/zettles/${zettle.id}/`,
      title: zettle.data.title,
      date: zettle.data.date,
      excerpt: zettle.data.excerpt,
    }))}
  />
</Layout>
