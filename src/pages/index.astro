---
import { getCollection } from "astro:content";
import Layout from "@/layouts/layout.astro";
import { buttonVariants } from "@/components/ui/button";

const posts = (await getCollection("posts"))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

const formatDate = (date: Date) =>
  date.toLocaleDateString("en-US", { year: "numeric", month: "short" });

// contact happens via socials — no email on purpose
const socialLinks = [
  { href: "https://x.com/ianuragbanerjee", label: "X" },
  { href: "https://github.com/banuragaxioned", label: "GitHub" },
  { href: "https://linkedin.com/in/imanuragbanerjee", label: "LinkedIn" },
];
---

<Layout>
  <section>
    <h1 class="text-3xl font-semibold tracking-tight">Hey, I'm Anurag 👋</h1>
    <p class="text-muted-foreground mt-4">
      Tech enthusiast, Liverpool FC supporter. I post random things. All views
      are my own. 🇮🇳 🗺️ 🎧 ⚽ 🍛🍕🍳🍔
    </p>
    <div class="mt-6 flex flex-wrap gap-3">
      {
        socialLinks.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="me"
            class={buttonVariants({ variant: "outline", size: "sm" })}
          >
            {link.label}
          </a>
        ))
      }
    </div>
  </section>

  <section class="mt-16">
    <ul class="flex flex-col gap-3">
      {
        posts.map((post) => (
          <li class="flex items-baseline justify-between gap-x-4">
            <a href={`/posts/${post.id}/`} class="hover:underline">
              {post.data.title}
            </a>
            <time
              datetime={post.data.date.toISOString()}
              class="text-muted-foreground shrink-0 text-sm"
            >
              {formatDate(post.data.date)}
            </time>
          </li>
        ))
      }
    </ul>
    <a
      href="/posts"
      class="text-muted-foreground hover:text-foreground mt-6 inline-block text-sm transition-colors"
      >All posts →</a
    >
  </section>
</Layout>
