---
import { getCollection } from "astro:content";
import Layout from "@/layouts/layout.astro";
import EntryList from "@/components/entry-list.astro";
import { buttonVariants } from "@/components/ui/button";
import { cn } from "@/lib/utils";

const posts = (await getCollection("posts"))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

// contact happens via socials — no email on purpose
const socialLinks = [
  { href: "https://x.com/ianuragbanerjee", label: "X" },
  { href: "https://github.com/banuragaxioned", label: "GitHub" },
  { href: "https://linkedin.com/in/imanuragbanerjee", label: "LinkedIn" },
];
---

<Layout>
  <section>
    <h1 class="text-3xl font-semibold tracking-tight">Hey, I'm Anurag 👋</h1>
    <p class="text-muted-foreground mt-4">
      Tech enthusiast, Liverpool FC supporter. I post random things. All views
      are my own. 🇮🇳 🗺️ 🎧 ⚽ 🍛🍕🍳🍔
    </p>
    <div class="mt-6 flex flex-wrap gap-3">
      {
        socialLinks.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="me"
            class={buttonVariants({ variant: "outline", size: "sm" })}
          >
            {link.label}
          </a>
        ))
      }
    </div>
  </section>

  <section class="mt-14">
    <div class="mb-6 flex items-baseline justify-between">
      <h2
        class="text-muted-foreground text-sm font-medium tracking-wide uppercase"
      >
        Recent posts
      </h2>
      <a
        href="/posts"
        class={cn(
          buttonVariants({ variant: "link", size: "sm" }),
          "text-muted-foreground px-0",
        )}>All posts →</a
      >
    </div>
    <EntryList
      entries={posts.map((post) => ({
        href: `/posts/${post.id}/`,
        title: post.data.title,
        date: post.data.date,
        excerpt: post.data.excerpt,
      }))}
    />
  </section>
</Layout>
